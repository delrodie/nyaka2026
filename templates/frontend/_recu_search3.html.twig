{% extends 'base.html.twig' %}

{% block title %} {{ participant.nomPrenoms|title }}  - {{ participant.matricule}} {% endblock %}

{% block body %}
    <div class="overflow-hidden">
        <div class="logo">
            <div class="logo-icon">
                <img src="{{ absolute_url(asset('images/logo-cvav.png')) }}" alt="" class="img-fluid activite">
            </div>
            <div class="logo-text">
                <h2 class="titre-activite">N'yâkâ Nansi 2026</h2>
                <h3>Je participe à cette édition</h3>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="formulaire">
            <div class="text-center mt-5 mb-5">
                <h2 class="titre">Mon reçu</h2>
            </div>
        </div>

        <div id="recu-wrapper">

            <div class="recu-header text-center mb-3">
                <img id="recu-logo"
                     src="{{ absolute_url(asset('images/logo-cvav.png')) }}"
                     alt="Logo CVAV"
                     style="max-height: 60px; margin-bottom: 6px;">
                <h2 style="margin: 4px 0 0;">N'yâkâ Nansi 2026</h2>
                <p style="margin: 2px 0 0; font-style: italic;">Je participe à cette édition</p>
                <hr style="margin: 8px 0;">
                <h3 style="margin: 0;">Mon reçu</h3>
            </div>

            <div class="recu">
                <div class="recu-inner">
                    <div class="recu-row">
                        <span class="libelle">ID Unique</span>
                        <span class="matricule">: {{ participant.matricule }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Nom et prénoms</span>
                        <span class="valeur">: {{ participant.nomPrenoms }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Genre</span>
                        <span class="valeur">: {{ participant.genre }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Nom déclarant</span>
                        <span class="valeur">: {{ participant.declarantNom }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Contact déclarant</span>
                        <span class="valeur">: {{ participant.declarantContact }}</span>
                    </div>
                    <hr>
                    <div class="recu-row">
                        <span class="libelle">Vicariat</span>
                        <span class="valeur">: {{ participant.section.doyenne.vicariat.nom }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Doyenné</span>
                        <span class="valeur">: {{ participant.section.doyenne.nom }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Section</span>
                        <span class="valeur">: {{ participant.section.nom }}</span>
                    </div>
                    <hr>
                    <div class="recu-row">
                        <span class="libelle">Grade</span>
                        <span class="valeur">: {{ participant.grade.nom }}</span>
                    </div>
                    <div class="recu-row">
                        <span class="libelle">Taille tee-shirt</span>
                        <span class="valeur">: {{ participant.taille }}</span>
                    </div>
                    <div class="recu-row recu-row--montant">
                        <span class="libelle">Montant payé</span>
                        <span class="montant">: {{ participant.montant|number_format(0,'','.') }} FCFA</span>
                    </div>
                    <div class="recu-row recu-row--date">
                        <em>Inscrit le {{ participant.waveWhenCreated|date('d-m-Y H:i:s') }}</em>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="text-center mt-4" id="action-buttons">
        <a href="{{ absolute_url(path('app_home')) }}" id="btnRetour" class="btn btn-outline-secondary btn-sm">Retour</a>
        <button id="print-button" class="btn btn-outline-primary btn-sm">Imprimer</button>
        <button id="pdf-button" class="btn btn-outline-danger btn-sm">Exporter en PDF</button>
    </div>

    <div id="loader-overlay" style="display:none;">
        <div class="loader"></div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Styles de la page ── */
        .recu {
            background: white;
            padding: 12px;
        }
        .recu-inner {
            font-size: 0.88rem;
        }
        .recu-row {
            display: flex;
            gap: 6px;
            margin-bottom: 6px;
        }
        .recu-row .libelle {
            flex: 0 0 130px;
            font-weight: 600;
            color: #444;
        }
        .recu-row .valeur,
        .recu-row .matricule,
        .recu-row .montant {
            flex: 1;
        }
        .recu-row--montant .montant {
            font-weight: 700;
            color: #1a6e2e;
        }
        .recu-row--date {
            margin-top: 10px;
            justify-content: flex-end;
            font-size: 0.78rem;
            color: #666;
        }

        /* En-tête du reçu : caché sur la page web normale */
        .recu-header {
            display: none;
        }

        /* ══════════════════════════════════════════════
           @media print — Format A6
           ══════════════════════════════════════════════ */
        @media print {
            /* ✅ Définir le format A6 */
            @page {
                size: A6 portrait;
                margin: 10mm;
            }

            /* Masquer ce qui ne doit pas s'imprimer */
            #print-button, #btnRetour, #pdf-button,
            #action-buttons, .logo, .formulaire,
            #loader-overlay, nav, header, footer {
                display: none !important;
            }

            /* Neutraliser les animations AOS */
            [data-aos] {
                opacity: 1 !important;
                transform: none !important;
                transition: none !important;
                animation: none !important;
            }

            /* ✅ Afficher l'en-tête du reçu (logo + titre) */
            .recu-header {
                display: block !important;
            }

            /* Pleine largeur */
            #recu-wrapper, .recu, .recu-inner {
                width: 100% !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            /* Adapter la taille du texte au format A6 */
            .recu-inner {
                font-size: 9pt;
            }
            .recu-row .libelle {
                flex: 0 0 100px;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ✅ FIX LOGO : pré-convertir le logo en base64 dès le chargement de la page
            // Cela contourne les restrictions CORS de html2canvas
            var logoBase64 = null;
            var logoEl = document.getElementById('recu-logo');

            if (logoEl) {
                fetch(logoEl.src)
                    .then(function (res) { return res.blob(); })
                    .then(function (blob) {
                        var reader = new FileReader();
                        reader.onloadend = function () {
                            logoBase64 = reader.result; // stocké pour la capture PDF
                        };
                        reader.readAsDataURL(blob);
                    })
                    .catch(function () {
                        console.warn('Logo non convertible en base64.');
                    });
            }

            // ── Impression native ──
            var printBtn = document.getElementById('print-button');
            if (printBtn) {
                printBtn.addEventListener('click', function () {
                    window.print();
                });
            }

            // ── Exportation PDF ──
            var pdfBtn = document.getElementById('pdf-button');
            if (pdfBtn) {
                pdfBtn.addEventListener('click', function () {

                    var element = document.getElementById('recu-wrapper');
                    var loader  = document.getElementById('loader-overlay');
                    if (loader) loader.style.display = 'flex';

                    // ✅ Format A6 : 10.5 cm × 14.8 cm
                    var options = {
                        margin: [0.8, 0.8, 0.8, 0.8],
                        filename: 'Recu_{{ participant.matricule }}.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: {
                            scale: 2,
                            useCORS: true,
                            allowTaint: false,
                            logging: false,
                            onclone: function (clonedDoc) {

                                // ✅ Injecter le logo base64 dans le clone avant la capture
                                var clonedLogo = clonedDoc.getElementById('recu-logo');
                                if (clonedLogo) {
                                    if (logoBase64) {
                                        clonedLogo.src = logoBase64;
                                    } else {
                                        // Si le fetch a échoué, masquer l'image pour éviter une icône cassée
                                        clonedLogo.style.display = 'none';
                                    }
                                }

                                // Afficher l'en-tête (logo + titre) dans le PDF
                                clonedDoc.querySelectorAll('.recu-header').forEach(function (el) {
                                    el.style.display = 'block';
                                });

                                // Neutraliser AOS
                                clonedDoc.querySelectorAll('[data-aos]').forEach(function (el) {
                                    el.removeAttribute('data-aos');
                                    el.style.opacity    = '1';
                                    el.style.transform  = 'none';
                                    el.style.transition = 'none';
                                });
                            }
                        },
                        // ✅ Format A6
                        jsPDF: { unit: 'cm', format: [10.5, 14.8], orientation: 'portrait' }
                    };

                    html2pdf()
                        .set(options)
                        .from(element)
                        .save()
                        .then(function () {
                            if (loader) loader.style.display = 'none';
                        })
                        .catch(function (err) {
                            console.error('Erreur PDF :', err);
                            if (loader) loader.style.display = 'none';
                        });
                });
            }
        });
    </script>
{% endblock %}
