{% extends 'base.html.twig' %}

 {% block bg_body %} style="background: #fff"{% endblock %}

{% block turbo_frame %}
    <turbo-frame id="main-frame">
        {% block body %}
            <div class="max-w-sm mx-auto"
                 data-controller="inscription-membre inscription"
                 data-inscription-membre-grade-value=""
                 data-inscription-membre-tarifs-value="{{ tarifs|json_encode }}"
            >
                {{ include('frontend/_header.html.twig') }}

                <div class="espace inter-font-family px-3 mt-5" style="">
                    <div class="text-start">
                        <h3 class="fw-bold">Je m'inscris</h3>

{#                        <form action=""#}
{#                              method="POST" class="mt-3"#}
{#                              data-turbo="false"#}
{#                              data-action="submit->inscription#submitForm"#}
{#                        >#}
                            {{ form_start(form,{
                                'attr':{
                                    'data-turbo': false,
                                    'data-action': "submit->inscription#submitForm"
                                }
                            }) }}
                            <strong>Mes informations</strong>
                            <div class="mt-3 mb-3">
                                {# Zone ID #}
                                <div class="mt-3" id="zone-rechercheID" data-recherche-target="idZone">
                                    <div class="form-group">
                                        <div class="mb-3">{{ form_row(form.section) }}</div>
                                        <div class="mb-3">{{ form_row(form.nomPrenoms) }}</div>
                                        <div class="mb-3">{{ form_row(form.genre) }}</div>
                                        <div class="mb-3">{{ form_row(form.age) }}</div>
                                        <div class="mb-3">{{ form_row(form.grade) }}</div>
                                    </div>
                                </div>

                                {# Zone Nom + Doyenné #}
                                <div class="mt-5 d-none" id="zone-rechercheNom" data-recherche-target="nomZone">
                                    <div class="form-group">
                                        <div class="mb-3">
                                            <label for="doyenne" class="form-label">Doyenné</label>
                                            <select name="doyenne" id="doyenne"
                                                    class="form-select form-control-lg rounded-0"
                                                    data-recherche-target="doyenneSelect">
                                                <option value="">Chargement...</option>
                                            </select>
                                        </div>
                                        <div class="mb-3">
                                            <label for="nom" class="form-label">Nom et prénoms</label>
                                            <input type="text" name="nom" class="form-control form-control-lg rounded-0" id="nom">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr class="mt-5 mb-3">
                            <strong>Formulaire</strong>
                            <div class="form-group mt-3">
                                <div class="mb-3">
                                    <label for="profil" class="form-label fst-italic text-muted">Profil <sup class="text-danger">*</sup></label>
                                    <select name="profil" id="profil" class="form-select rounded-0"
                                            data-inscription-membre-target="profilSelect"
                                            data-action="change->inscription-membre#updateForm">
                                        <option value="Participant simple">Participant simple</option>
                                        <option value="Comité d'organisation">Comité d'organisation</option>
                                    </select>
                                </div>

                                <div class="mt-3" id="selectBenjamin" data-inscription-membre-target="sizeZone">
                                    <label for="tailleBenjamin" class="form-label fst-italic text-muted">Taille <sup class="text-danger">*</sup></label>
                                    <select name="tailleBenjamin" id="tailleBenjamin" class="form-select rounded-0">
                                        <option value="">-- Sélectionnez votre taille --</option>
                                        <option value="1-3">1-3 ans</option>
                                        <option value="4-6ans">4-6 ans</option>
                                        <option value="7-9ans">7-9 ans</option>
                                        <option value="10-12ans">10-12 ans</option>
                                    </select>
                                </div>

                                <div class="mt-3" id="selectAine" data-inscription-membre-target="sizeZone">
                                    <label for="tailleAine" class="form-label fst-italic text-muted">Taille <sup class="text-danger">*</sup></label>
                                    <select name="tailleAine" id="tailleAine" class="form-select rounded-0">
                                        <option value="">-- Sélectionnez votre taille --</option>
                                        <option value="M">M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                    </select>
                                </div>

                                <div class="mt-3" id="selectAA" data-inscription-membre-target="sizeZone">
                                    <label for="tailleAA" class="form-label fst-italic text-muted">Taille <sup class="text-danger">*</sup></label>
                                    <select name="tailleAA" id="tailleAA" class="form-select rounded-0">
                                        <option value="">-- Sélectionnez votre taille --</option>
                                        <option value="M">M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                        <option value="XXXL">XXXL</option>
                                    </select>
                                </div>

                                <div class="mt-3" id="selectAP" data-inscription-membre-target="sizeZone">
                                    <label for="tailleAP" class="form-label fst-italic text-muted">Taille <sup class="text-danger">*</sup></label>
                                    <select name="tailleAP" id="tailleAP" class="form-select rounded-0">
                                        <option value="">-- Sélectionnez votre taille --</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                        <option value="XXXL">XXXL</option>
                                    </select>
                                </div>

                                <div class="mt-3 mb-4">{{ form_row(form.traitement) }}</div>

                                <div class="mt-3">{{ form_row(form.declarantNom) }}</div>
                                <div class="mt-3 mb-3">{{ form_row(form.declarantContact) }}</div>
                                <div class="mt-3">.</div>
                                <div class="mt-3 text-center">
                                    <span class="bg-danger-subtle text-center fw-bold py-3 px-5"
                                          data-inscription-membre-target="montantAffiche"
                                          style="width: 100%;">0 F</span>
                                </div>

                            </div>

                            <div class="mt-5 mb-5">
                                <input type="hidden" name="participant" value="">
                                <input type="hidden"
                                       name="montant"
                                       data-inscription-membre-target="montantInput"
                                       data-inscription-target="montantInput"
                                       value="0"
                                >

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary rounded-0" data-inscription-target="submitButton">S'inscrire</button>
                                </div>
                            </div>
                            <div class="mt-3">.</div>
                            {{ form_end(form) }}
                    </div>
                </div>
            </div>
        {% endblock %}
    </turbo-frame>
{% endblock %}

