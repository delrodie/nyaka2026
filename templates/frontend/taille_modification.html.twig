{% extends 'base.html.twig' %}

 {% block bg_body %} style="background: #fff"{% endblock %}

{% block turbo_frame %}
    <turbo-frame id="main-frame">
        {% block body %}
            <div class="max-w-sm mx-auto">
                {{ include('frontend/_header.html.twig') }}

                <div class="espace inter-font-family px-3 mt-5" style="">
                    <div class="text-start">
                        <h3 class="fw-bold">Taille T-shirt</h3>

                        <form action="{{ path('app_taille_update', {'matricule': participant.slug}) }}"
                              method="POST" class="mt-3"
                              data-turbo="false"
                        >
                            <div class="mt-3 mb-3">
                                {# Zone ID #}
                                <div class="mt-3" id="zone-rechercheID" data-recherche-target="idZone">
                                    <div class="form-group">
                                        <div class="mb-3">
                                            <label for="IDUnique" class="form-label text-muted fst-italic">ID Unique (adhésion)</label>
                                            <input type="text" name="matricule" class="form-control rounded-0" value="{{ participant.matricule }}" readonly disabled>
                                        </div>
                                        <div class="mb-3">
                                            <label for="matricule" class="form-label text-muted fst-italic">Nom & prenoms</label>
                                            <input type="text" name="matricule" class="form-control rounded-0" value="{{ participant.nomPrenoms }}" readonly disabled>
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <div class="form-group mt-3">

                                <div class="mt-3" id="selectAine">
                                    <label for="tailleAine" class="form-label fst-italic text-muted">Taille <sup class="text-danger">*</sup></label>
                                    <select name="tailleAine" id="tailleAine" class="form-select rounded-0">
                                        <option value="">-- Sélectionnez votre taille --</option>
                                        <option value="M">M</option>
                                        <option value="L">L</option>
                                        <option value="XL">XL</option>
                                        <option value="XXL">XXL</option>
                                    </select>
                                </div>

                            </div>

                            <div class="mt-5 mb-5">

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary rounded-0" data-inscription-target="submitButton">S'inscrire</button>
                                </div>
                            </div>
                            <div class="mt-3">.</div>
                        </form>
                    </div>
                </div>
            </div>
        {% endblock %}
    </turbo-frame>
{% endblock %}

