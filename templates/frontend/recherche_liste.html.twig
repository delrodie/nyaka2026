{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-sm mx-auto p-3">
        <div class="overflow-hidden">
            <div class="logo">
                <div class="logo-icon">
                    <img src="{{ asset('images/logo-cvav.png') }}" alt="Logo CVAV" class="img-fluid">
                </div>
                <div class="logo-text">
                    <h4>Coeurs Vaillants Ames Vaillantes</h4>
                    <h5>Diocèse d'Abidjan</h5>
                </div>
            </div>
        </div>

        <div class="text-center inter-font-family mb-4 mt-5">
            <h3 class="fw-bold">Plusieurs comptes trouvés</h3>
            <p class="text-muted">Veuillez sélectionner votre profil dans la liste ci-dessous pour continuer votre inscription.</p>
        </div>

        <div class="list-group inter-font-family rounded-0">
            {% for adhesion in adhesions %}
                <a href="{{ path('app_inscription_membre', {'id': adhesion.id}) }}"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3">
                    <div>
                        <div class="fw-bold text-uppercase">{{ adhesion.nomPrenoms }}</div>
                        <small class="text-muted">
                            ID: {{ adhesion.matricule }} | {{ adhesion.section ? adhesion.section.nom : 'Sans section' }}
                        </small>
                    </div>
                    <i class="fas fa-chevron-right text-primary"></i>
                </a>
            {% endfor %}
        </div>

        <div class="mt-5 text-center d-grid gap-2">
            <a href="{{ path('app_inscription_recherche') }}" class="btn btn-outline-secondary text-decoration-none">
                <i class="fas fa-arrow-left"></i> Recommencer la recherche
            </a>
        </div>
    </div>
{% endblock %}
