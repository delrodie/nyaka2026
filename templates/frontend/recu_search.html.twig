{% extends 'base.html.twig' %}

{% block title %} {{ participant.nomPrenoms|title }} - {{ participant.matricule }} {% endblock %}

{% block body %}

    <div class="overflow-hidden">
        <div class="logo">
            <div class="logo-icon">
                <img src="{{ absolute_url(asset('images/logo-cvav.png')) }}" alt="" class="img-fluid activite">
            </div>
            <div class="logo-text">
                <h2 class="titre-activite">N'yâkâ Nansi 2026</h2>
                <h3>Je participe à cette édition</h3>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="formulaire">
            <div class="text-center mt-5 mb-4">
                <h2 class="titre">Mon reçu</h2>
            </div>
        </div>

        <div id="recu-wrapper">

            <div class="r-header">
                <div class="r-header-left">
                    <img id="recu-logo"
                         src="{{ absolute_url(asset('images/logo-cvav.png')) }}"
                         alt="Logo CVAV"
                         class="r-logo">
                </div>
                <div class="r-header-center">
                    <div class="r-event-name">N'YÂKÂ NANSI 2026</div>
                    <div class="r-event-sub">Je participe à cette édition</div>
                </div>
                <div class="r-header-right">
                    <div class="r-doc-label">REÇU</div>
                    <div class="r-doc-id">{{ participant.matricule }}</div>
                </div>
            </div>

            <div class="r-banner">
                <span>REÇU DE PARTICIPATION</span>
            </div>

            <div class="r-body">

                <div class="r-block">
                    <div class="r-block-title">
                        <span class="r-block-icon">👤</span> Participant
                    </div>
                    <table class="r-table">
                        <tr>
                            <th>Nom et prénoms</th>
                            <td colspan="3"><strong>{{ participant.nomPrenoms|upper }}</strong></td>

                        </tr>
                        <tr>
                            <th>Matricule</th>
                            <td>{{ participant.matricule }}</td>
                            <th>Genre</th>
                            <td>{{ participant.genre }}</td>
                        </tr>
                        <tr>
                            <th>Grade</th>
                            <td>{{ participant.grade ? participant.grade.nom : 'INVITE' }}</td>
                            <th>Taille tee-shirt</th>
                            <td>{{ participant.taille }}</td>
                        </tr>
                    </table>
                </div>

                <div class="r-block">
                    <div class="r-block-title">
                        <span class="r-block-icon">📋</span> Déclarant
                    </div>
                    <table class="r-table">
                        <tr>
                            <th>Nom</th>
                            <td><strong>{{ participant.declarantNom|title }}</strong></td>
                            <th>Contact</th>
                            <td>{{ participant.declarantContact }}</td>
                        </tr>
                    </table>
                </div>

                <div class="r-block">
                    <div class="r-block-title">
                        <span class="r-block-icon">📍</span> Localisation
                    </div>
                    <table class="r-table">
                        <tr>
                            <th>Vicariat</th>
                            <td colspan="3">{{ participant.section.doyenne.vicariat.nom }}</td>
                        </tr>
                        <tr>
                            <th>Doyenné</th>
                            <td>{{ participant.section.doyenne.nom }}</td>
                            <th>Section</th>
                            <td>{{ participant.section.nom }}</td>
                        </tr>
                    </table>
                </div>

                <div class="r-payment">
                    <div class="r-payment-left">
                        <div class="r-payment-label">Montant réglé</div>
                        <div class="r-payment-date">
                            Inscrit le {{ participant.waveWhenCreated|date('d/m/Y à H:i') }}
                        </div>
                    </div>
                    <div class="r-payment-amount">
                        {{ participant.montant|number_format(0,'','.') }}<span class="r-currency">FCFA</span>
                    </div>
                </div>

            </div>

            <div class="r-footer">
                <div class="r-footer-left">Document officiel — N'yâkâ Nansi 2026</div>
                <div class="r-footer-right">Ce reçu atteste de votre inscription</div>
            </div>

        </div>

    </div>

    <div class="text-center mt-4" id="action-buttons">
        <a href="{{ absolute_url(path('app_home')) }}" id="btnRetour" class="btn btn-outline-secondary btn-sm">
            ← Retour
        </a>
        <button id="print-button" class="btn btn-outline-primary btn-sm">🖨 Imprimer</button>
        <button id="pdf-button"   class="btn btn-danger btn-sm">⬇ Exporter en PDF</button>
    </div>

    <div id="loader-overlay" style="display:none;">
        <div class="loader"></div>
    </div>

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>

        /* ════════════════════════════════════════════════════
           VARIABLES
           ════════════════════════════════════════════════════ */
        :root {
            --primary:   #00acef;
            --primary-light: rgb(234 241 245);
            /*--accent:    #f0a500;*/
            --accent: #fff;
            --text:      #1a1a1a;
            --muted:     #6b7280;
            --border:    #d1d5db;
            --radius:    6px;
        }

        /* ════════════════════════════════════════════════════
           WRAPPER — pas de hauteur fixe ! Le contenu détermine la taille.
           ════════════════════════════════════════════════════ */
        #recu-wrapper {
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            font-family: 'Segoe UI', Arial, sans-serif;
            color: var(--text);
            font-size: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        /* ── En-tête ── */
        .r-header {
            display: flex;
            align-items: center;
            background: var(--primary);
            color: #fff;
            padding: 12px 16px;
            gap: 12px;
        }
        .r-logo {
            height: 48px;
            width: auto;
            object-fit: contain;
            background: #fff;
            border-radius: 4px;
            padding: 3px;
        }
        .r-header-center {
            flex: 1;
        }
        .r-event-name {
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.05em;
            line-height: 1.2;
        }
        .r-event-sub {
            font-size: 10px;
            opacity: 0.85;
            font-style: italic;
        }
        .r-header-right {
            text-align: right;
        }
        .r-doc-label {
            font-size: 9px;
            opacity: 0.75;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
        .r-doc-id {
            font-size: 10px;
            font-weight: bold;
            color: var(--accent);
            letter-spacing: 0.06em;
        }

        /* ── Bandeau titre ── */
        .r-banner {
            background: var(--muted);
            color: #fff;
            text-align: center;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            padding: 4px 0;
        }

        /* ── Corps ── */
        .r-body {
            padding: 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        /* ── Blocs de section ── */
        .r-block {
            border: 1px solid var(--border);
            border-radius: 4px;
            overflow: hidden;
        }
        .r-block-title {
            background: var(--primary-light);
            color: var(--primary);
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            padding: 4px 10px;
            border-bottom: 1px solid var(--border);
        }
        .r-block-icon {
            margin-right: 4px;
        }

        /* ── Tableau de données ── */
        .r-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }
        .r-table tr {
            border-bottom: 1px solid #f0f0f0;
        }
        .r-table tr:last-child {
            border-bottom: none;
        }
        .r-table th {
            background: #fafafa;
            color: var(--muted);
            font-size: 9px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 5px 10px;
            white-space: nowrap;
            width: 22%;
            vertical-align: top;
        }
        .r-table td {
            padding: 5px 10px;
            color: var(--text);
            vertical-align: top;
        }

        /* ── Paiement ── */
        .r-payment {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--primary);
            border-radius: 4px;
            padding: 10px 14px;
            color: #fff;
        }
        .r-payment-label {
            font-size: 11px;
            font-weight: 700;
            opacity: 0.9;
        }
        .r-payment-date {
            font-size: 9px;
            opacity: 0.7;
            margin-top: 2px;
            font-style: italic;
        }
        .r-payment-amount {
            font-size: 22px;
            font-weight: 900;
            color: var(--accent);
            line-height: 1;
        }
        .r-currency {
            font-size: 12px;
            font-weight: 600;
            margin-left: 4px;
            opacity: 0.85;
        }

        /* ── Pied ── */
        .r-footer {
            display: flex;
            justify-content: space-between;
            background: #f7f7f7;
            border-top: 1px solid var(--border);
            padding: 6px 16px;
            font-size: 9px;
            color: var(--muted);
            font-style: italic;
        }

        /* ════════════════════════════════════════════════════
           @media print — Format A6, une seule page
           ════════════════════════════════════════════════════ */
        @media print {
            @page {
                size: A6 portrait;
                margin: 6mm;
            }

            /* Masquer tout sauf le reçu */
            body * { visibility: hidden; }
            #recu-wrapper, #recu-wrapper * { visibility: visible; }

            #recu-wrapper {
                position: absolute;
                top: 0; left: 0;
                width: 100% !important;
                max-width: 100% !important;
                border: none !important;
                box-shadow: none !important;
                font-size: 8px !important;
            }

            .r-header { padding: 8px 10px; }
            .r-logo   { height: 34px; }
            .r-event-name { font-size: 10px; }
            .r-doc-id     { font-size: 11px; }
            .r-body       { padding: 8px 10px; gap: 6px; }
            .r-table      { font-size: 8px; }
            .r-table th   { font-size: 7px; padding: 3px 7px; }
            .r-table td   { padding: 3px 7px; }
            .r-payment    { padding: 6px 10px; }
            .r-payment-amount { font-size: 16px; }
            .r-block-title { font-size: 7px; padding: 3px 7px; }

            [data-aos] {
                opacity: 1 !important;
                transform: none !important;
                transition: none !important;
            }
        }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function () {

        /* ── Pré-charger le logo en base64 (contourne CORS html2canvas) ── */
        var logoBase64 = null;
        var logoEl = document.getElementById('recu-logo');
        if (logoEl) {
            fetch(logoEl.src)
                .then(function (r) { return r.blob(); })
                .then(function (b) {
                    var rd = new FileReader();
                    rd.onloadend = function () { logoBase64 = rd.result; };
                    rd.readAsDataURL(b);
                })
                .catch(function () { console.warn('Logo : conversion base64 impossible.'); });
        }

        /* ── Impression native ── */
        document.getElementById('print-button').addEventListener('click', function () {
            window.print();
        });

        /* ── Exportation PDF ── */
        document.getElementById('pdf-button').addEventListener('click', function () {

            var wrapper = document.getElementById('recu-wrapper');
            var loader  = document.getElementById('loader-overlay');
            if (loader) loader.style.display = 'flex';

            // Dimensions A6 en mm
            var A6_W = 105;
            var A6_H = 148;
            var MARGIN = 5; // mm

            var captureOptions = {
                scale: 2,           // haute résolution
                useCORS: true,
                allowTaint: false,
                backgroundColor: '#ffffff',
                logging: false,
                onclone: function (clonedDoc) {
                    /* Injecter le logo base64 */
                    var cl = clonedDoc.getElementById('recu-logo');
                    if (cl && logoBase64) { cl.src = logoBase64; }

                    /* Neutraliser AOS */
                    clonedDoc.querySelectorAll('[data-aos]').forEach(function (el) {
                        el.removeAttribute('data-aos');
                        el.style.opacity    = '1';
                        el.style.transform  = 'none';
                        el.style.transition = 'none';
                    });

                    /* Supprimer le box-shadow (inutile dans le PDF) */
                    var w = clonedDoc.getElementById('recu-wrapper');
                    if (w) { w.style.boxShadow = 'none'; }
                }
            };

            html2canvas(wrapper, captureOptions).then(function (canvas) {

                var { jsPDF } = window.jspdf;
                var pdf = new jsPDF({ unit: 'mm', format: 'a6', orientation: 'portrait' });

                /* Zone utile après marges */
                var usableW = A6_W - MARGIN * 2;
                var usableH = A6_H - MARGIN * 2;

                /* Ratio canvas → mm */
                var canvasW = canvas.width;
                var canvasH = canvas.height;
                var ratio   = canvasW / canvasH;

                /* Calculer les dimensions en respectant les proportions */
                var imgW = usableW;
                var imgH = usableW / ratio;

                /* Si trop haut, réduire à la hauteur utile */
                if (imgH > usableH) {
                    imgH = usableH;
                    imgW = usableH * ratio;
                }

                /* Centrer horizontalement */
                var offsetX = MARGIN + (usableW - imgW) / 2;
                var offsetY = MARGIN;

                var imgData = canvas.toDataURL('image/jpeg', 0.97);
                pdf.addImage(imgData, 'JPEG', offsetX, offsetY, imgW, imgH);
                pdf.save('Recu_{{ participant.matricule }}.pdf');

                if (loader) loader.style.display = 'none';

            }).catch(function (err) {
                console.error('Erreur export PDF :', err);
                if (loader) loader.style.display = 'none';
            });
        });

    });
    </script>
{% endblock %}
